<!-- Multi Tag Clouds Sidebar with full backward compatibility -->
<% if @project %>
  <% tag_clouds = @project.tag_clouds.order(:position, :id) %>
  <% tag_clouds.each do |cloud| %>
    <div class="sidebar-tag-cloud">
      <h3><%= cloud.name %></h3>
      <% if cloud.is_system? %>
        <%= render_sidebar_tags if defined?(render_sidebar_tags) %>
      <% else %>
        <!-- Placeholder for custom cloud tags - extend with Aggregator in next stage -->
        <p class="info">[Custom cloud tags - filters: <%= cloud.status_filter.present? ? 'active' : 'all' %>]</p>
      <% end %>
    </div>
  <% end %>
<% end %>

<!-- Fallback to original single cloud -->
<% if defined?(sidebar_tags) && !sidebar_tags.empty? %>
  <div class="sidebar-tags">
    <h3><%= l(:tags) %></h3>
    <%= render_sidebar_tags if defined?(render_sidebar_tags) %>
  </div>
<% end %>