<!-- Safe sidebar for tags - restores original behavior and adds multi-cloud structure -->
<% if defined?(render_sidebar_tags) %>
  <%= render_sidebar_tags %>
<% end %>

<!-- Multi cloud placeholder - will be expanded with Aggregator in next stage -->
<% if @project && @project.tag_clouds.any? %>
  <% @project.tag_clouds.order(:position).each do |cloud| %>
    <% if !cloud.is_system? %>
      <div class="sidebar-tag-cloud">
        <h3><%= cloud.name %></h3>
        <p class="info">Custom cloud tags (to be implemented with full aggregator)</p>
      </div>
    <% end %>
  <% end %>
<% end %>