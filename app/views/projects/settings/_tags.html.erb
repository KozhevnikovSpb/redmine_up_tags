<h3><%= l(:tag_clouds) %></h3>

<% if @project.present? %>
  <% TagCloud.ensure_system_cloud(@project) %>
  <% @tag_clouds = @project.tag_clouds.order(:position, :id) %>
<% end %>

<% if @tag_clouds && @tag_clouds.any? %>
  <table class="list">
    <thead>
      <tr>
        <th><%= l(:label_tag_cloud_name, default: 'Name') %></th>
        <th><%= l(:label_tag_cloud_filters, default: 'Filters') %></th>
        <th><%= l(:label_tag_cloud_visible_by_default, default: 'Visible by default') %></th>
        <th><%= l(:label_tag_cloud_position, default: 'Position') %></th>
        <th class="actions"></th>
      </tr>
    </thead>
    <tbody>
      <% @tag_clouds.each_with_index do |cloud, idx| %>
        <tr class="<%= idx.even? ? 'even' : 'odd' %><%= ' system' if cloud.is_system? %>">
          <td>
            <%= cloud.name %>
            <% if cloud.is_system? %>
              <span class="badge badge-info" style="margin-left: 5px;"><%= l(:label_tag_cloud_system, default: 'system') %></span>
            <% end %>
          </td>
          <td><%= tag_cloud_filters_summary(cloud) %></td>
          <td><%= cloud.visible_by_default ? '✓' : '—' %></td>
          <td><%= cloud.position %></td>
          <td class="actions">
            <%= link_to l(:button_edit), edit_project_tag_cloud_path(@project, cloud), class: 'icon icon-edit' %>
            <% unless cloud.is_system? %>
              <%= link_to l(:button_delete),
                          project_tag_cloud_path(@project, cloud),
                          method: :delete,
                          data: { confirm: l(:text_are_you_sure) },
                          class: 'icon icon-del' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="nodata"><%= l(:label_no_data) %></p>
<% end %>

<p>
  <%= link_to l(:label_new_tag_cloud, default: 'New Tag Cloud'),
              new_project_tag_cloud_path(@project),
              class: 'icon icon-add button' %>
</p>

<p class="info"><%= l(:text_tag_clouds_info, default: 'Tag clouds allow multiple analytical views of issues with independent filters. System cloud is protected and always present.') %></p>